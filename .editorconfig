root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false
indent_size = 2

[*.{json,yml,yaml}]
indent_size = 2

[*.{xml}]
indent_size = 4

[*.gradle.kts]
indent_size = 4

[*.kt]
indent_size = 4
max_line_length = 120
# ktlint rules
ij_kotlin_allow_trailing_comma = true
ij_kotlin_allow_trailing_comma_on_call_site = true

[*.{properties}]
indent_size = 2
