<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
  <!-- Deny cleartext (HTTP) traffic by default — SSH runs its own encrypted transport -->
  <base-config cleartextTrafficPermitted="false">
    <trust-anchors>
      <certificates src="system" />
    </trust-anchors>
  </base-config>
</network-security-config>
